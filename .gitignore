# Ignore everything
*

# EXCEPT 

# .github folder to keep the README in
!/.github/
!/.github/README.md

# The .gitignore file itself
!/.gitignore

# Git-related configuration
!/.gitconfig

# Zsh & Shell configuration
!/.zshrc
!/.p10k.zsh

# Config directories. Whitelisting is NOT recursive: un-ignoring a directory
# only lets Git descend into it — each tracked file/subfolder needs its own !line.
!/.config/

# Ghostty
!/.config/ghostty/
!/.config/ghostty/config
