# Ignore everything
*

# EXCEPT 

# .github folder to keep the README in
!/.github/
!/.github/README.md

# The .gitignore file itself
!/.gitignore

# Git-related configuration
!/.gitconfig
!/.gitmodules

# Zsh & Shell configuration
!/.zshrc
!/.p10k.zsh

# Config directories (like nvim, etc.)
# The trailing slash is important! It ensures we can track files inside.
!/.config/

# Claude Code config — settings only.
# NOT history/projects/sessions/cache (machine-local, large) or settings.local.json (per-machine overrides).
!/.claude/
!/.claude/settings.json
